{
  "name": "Redmine Tools (Ruby 3.4)",
  "image": "mcr.microsoft.com/devcontainers/ruby:3.4",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "postCreateCommand": "npm install -g @google/gemini-cli",
  "mounts": [
    {
      "source": "${localEnv:HOME}/.gemini",
      "target": "/home/vscode/.gemini",
      "type": "bind",
      "consistency": "cached"
    }
  ],
  "containerEnv": {
    "REDMINE_URL": "${localEnv:REDMINE_URL}",
    "REDMINE_API_KEY": "${localEnv:REDMINE_API_KEY}",
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}",
    "GEMINI_CONFIG_DIR": "/home/vscode/.gemini"
  },
  "remoteUser": "vscode"
}
